# Токен Telegram-бота (от @BotFather)
BOT_TOKEN=1234567890:YOUR_TELEGRAM_BOT_TOKEN

# Telegram ID Администраторов (через запятую, для получения уведомлений и доступа в админ-панель)
ADMIN_IDS=123456789,987654321

# Включение модулей
RUN_TELEGRAM=True
RUN_API=True

# Настройки FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# URL для Telegram WebApp (необходим протокол https)
# Для локального тестирования через ngrok: https://ваш-поддомен.ngrok-free.app
# Для Railway: https://your-project-url.railway.app
WEBAPP_URL=https://localhost:8000

# Настройка БД (опционально, по умолчанию используется sqlite+aiosqlite:///app.db)
# DATABASE_URL=sqlite+aiosqlite:///app.db

# Redis URL (для дедупликации чеков и кэширования)
# REDIS_URL=redis://localhost:6379/0

# Секретный токен для WebSocket-клиента принтера
# Используется для авторизации подключения локального ПК с принтером
PRINTER_SECRET_TOKEN=your-super-secret-printer-token

# Telegram ID Тех.Администратора для ежедневных отчётов Log Analyzer
TECH_ADMIN_ID=123456789

# Время отправки ежедневного отчёта (HH:MM, по UZT +5)
LOG_REPORT_TIME=23:55
