# URL WebSocket-сервера (замените на ваш)
SERVER_WS_URL=wss://salesmanager.up.railway.app/ws/printer/{token}

# Секретный токен (должен совпадать с токеном на сервере)
SECRET_TOKEN=xprinter-sale-stock-2026-secret

# ВАШ ID ПРОДАВЦА (можно узнать в боте по команде /start)
SELLER_ID=

# Режим работы принтера: windows или usb
PRINTER_MODE=windows

# Имя принтера в системе (для режима windows)
PRINTER_NAME_WIN=POSPrinter POS58

# Порты USB (для режима usb, в HEX формате)
PRINTER_VENDOR_ID=0x0483
PRINTER_PRODUCT_ID=0x070B

# Настройки чека
SHOP_NAME=Sale & Stock Bot
RECEIPT_WIDTH=32

# Интервал переподключения
RECONNECT_DELAY=5
